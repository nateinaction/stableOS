{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "pinDigests": true,
  "pre-commit": {
    "enabled": true
  },
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": false,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Only track Fedora releases that have reached GA; bump this cap when the next Fedora version is released (GAs ~April/Oct).",
      "matchPackageNames": [
        "quay.io/fedora-ostree-desktops/cosmic-atomic"
      ],
      "allowedVersions": "<=44"
    }
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "/(^|/)Containerfile$/"
    ]
  }
}
