{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "pinDigests": true,
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": false,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "/(^|/)Containerfile$/"
    ]
  }
}
