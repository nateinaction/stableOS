// COSMIC shell configuration
// Global defaults applied to all new users at install time.
// Personal overrides should be applied via dotfiles (chezmoi).

(
    // Enable workspaces
    workspaces: (
        work_enabled: true,
        workspace_count: 4,
    ),
    // Panel defaults
    panel: (
        autohide: false,
        position: Bottom,
    ),
)
